# LiveKit
LIVEKIT_URL=wss://your-livekit-server.example.com
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# Anthropic (Claude LLM)
ANTHROPIC_API_KEY=sk-ant-...

# Deepgram (Speech-to-Text)
DEEPGRAM_API_KEY=...

# ElevenLabs (Text-to-Speech)
ELEVEN_API_KEY=sk_...

# Orchestra MCP
ORCHESTRA_MCP_ENDPOINT=https://your-firebase-project.cloudfunctions.net/mcpServer
ORCHESTRA_API_KEY=your_orchestra_api_key
ORCHESTRA_SPACE_UID=your_workspace_uid
ORCHESTRA_USER_UID=agent_member_uid
