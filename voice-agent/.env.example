# LiveKit (voice calls)
LIVEKIT_URL=wss://your-livekit-server.example.com
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# Anthropic (Claude LLM)
ANTHROPIC_API_KEY=sk-ant-...

# Deepgram (Speech-to-Text)
DEEPGRAM_API_KEY=...

# ElevenLabs (Text-to-Speech)
ELEVEN_API_KEY=sk_...
ELEVENLABS_VOICE_ID=ODq5zmih8GrVes37Dizd

# Orchestra MCP (fallback — normally passed via webhook payload)
ORCHESTRA_MCP_ENDPOINT=https://your-firebase-project.cloudfunctions.net/mcpServer
ORCHESTRA_API_KEY=your_orchestra_api_key
ORCHESTRA_SPACE_UID=your_workspace_uid

# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_PRIVATE_KEY=        # JSON array of secret key bytes
# SOLANA_KEYPAIR_PATH=     # Alternative: path to keypair file

# Webhook Server
WEBHOOK_PORT=8765
